# Backend API
VITE_API_BASE_URL=http://localhost:3000

# Google OAuth/OIDC
# Get this value from Google Cloud Console -> OAuth 2.0 Client IDs -> Web application
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Local frontend URL. Add this URL to Google Authorized JavaScript origins.
VITE_FRONTEND_URL=http://localhost:5173

# Optional reference only. Google Identity Services mainly requires Authorized JavaScript origins.
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173
