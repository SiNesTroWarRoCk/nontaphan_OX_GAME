# Server
PORT=3000
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ox_game?schema=public

# Google OAuth/OIDC
# Use the same client ID as frontend. Backend validates Google ID token audience against this value.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional. Not used for ID token verification, but kept for reference if adding OAuth code exchange later.
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173

# Generic OIDC verifier config.
# The implementation still reads these AUTH0_* names for backward compatibility,
# but these values are configured for Google OIDC.
AUTH0_DOMAIN=accounts.google.com
AUTH0_AUDIENCE=
AUTH0_ISSUER_URL=https://accounts.google.com
AUTH0_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs
